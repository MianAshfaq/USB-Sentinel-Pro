<Window x:Class="UsbSentinel.Desktop.FormatUsbDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Format USB storage" Width="500" Height="590" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False">
    <Border Padding="30" Background="{StaticResource BackgroundBrush}">
        <StackPanel>
            <TextBlock Text="FORMAT USB STORAGE" Foreground="{StaticResource DangerBrush}" FontSize="12" FontWeight="Bold"/>
            <TextBlock Text="Erase a removable volume" FontSize="25" FontWeight="SemiBold" Margin="0,14,0,10"/>
            <TextBlock Text="This permanently removes all files from the selected USB drive or portable HDD volume. Confirm the drive letter carefully. Quick format is not secure erasure."
                       Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap"/>
            <TextBlock Text="USB VOLUME" FontSize="10" Foreground="{StaticResource BlueBrush}" Margin="0,22,0,7"/>
            <ComboBox x:Name="DriveBox" ItemsSource="{Binding DriveChoices}" DisplayMemberPath="Summary" SelectionChanged="DriveChanged" Height="42"/>
            <TextBlock Text="FILE SYSTEM" FontSize="10" Foreground="{StaticResource BlueBrush}" Margin="0,16,0,7"/>
            <ComboBox x:Name="FileSystemBox" Height="38" SelectedIndex="0">
                <ComboBoxItem Content="exFAT" ToolTip="Best compatibility for large files across modern devices"/>
                <ComboBoxItem Content="NTFS" ToolTip="Windows permissions, journaling, and large-volume support"/>
            </ComboBox>
            <CheckBox x:Name="QuickBox" Content="Quick format" IsChecked="True" Margin="0,16,0,0"/>
            <TextBlock x:Name="PhraseHelp" Foreground="{StaticResource MutedBrush}" Margin="0,16,0,6"/>
            <TextBox x:Name="ConfirmationBox" Height="38"/>
            <TextBlock Text="ADMINISTRATOR PASSWORD" FontSize="10" Foreground="{StaticResource BlueBrush}" Margin="0,16,0,7"/>
            <PasswordBox x:Name="PasswordBox" Height="38"/>
            <Grid Margin="0,24,0,0">
                <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="12"/><ColumnDefinition/></Grid.ColumnDefinitions>
                <Button Content="CANCEL" IsCancel="True"/>
                <Button Grid.Column="2" Content="ERASE AND FORMAT" Background="{StaticResource DangerBrush}"
                        Foreground="White" Click="ConfirmClick"/>
            </Grid>
        </StackPanel>
    </Border>
</Window>
