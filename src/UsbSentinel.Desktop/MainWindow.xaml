<Window x:Class="UsbSentinel.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp"
        Title="USB Sentinel Pro" Width="1160" Height="760" MinWidth="960" MinHeight="660"
        WindowStartupLocation="CenterScreen" WindowState="Maximized">
    <Window.Resources>
        <Style x:Key="Panel" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="7"/>
            <Setter Property="Padding" Value="22"/>
        </Style>
        <Style x:Key="SidebarTab" TargetType="TabItem">
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Width" Value="174"/>
            <Setter Property="Height" Value="52"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="NavItem" Background="{TemplateBinding Background}"
                                BorderBrush="{StaticResource GreenBrush}" BorderThickness="0"
                                CornerRadius="5" Padding="18,0">
                            <ContentPresenter ContentSource="Header" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="NavItem" Property="Background" Value="#102329"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="NavItem" Property="Background" Value="#102A29"/>
                                <Setter TargetName="NavItem" Property="BorderThickness" Value="3,0,0,0"/>
                                <Setter Property="Foreground" Value="{StaticResource GreenBrush}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SecurityTabs" TargetType="TabControl">
            <Setter Property="Background" Value="{StaticResource BackgroundBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <Grid Background="{TemplateBinding Background}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="194"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Background="#081419" BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="0,0,1,0" Padding="10,16">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="SECURITY CONSOLE" FontSize="10" Foreground="{StaticResource BlueBrush}"
                                               Margin="12,0,0,14"/>
                                    <TabPanel Grid.Row="1" IsItemsHost="True" KeyboardNavigation.TabNavigation="Local"/>
                                    <StackPanel Grid.Row="2" Margin="12,0,8,6">
                                        <TextBlock Text="OPEN SOURCE" FontSize="9" Foreground="{StaticResource GreenBrush}"/>
                                        <TextBlock Text="Community Edition" FontSize="11" Foreground="{StaticResource MutedBrush}" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <Border Grid.Column="1" Background="{StaticResource BackgroundBrush}" Padding="22,0,0,0">
                                <ContentPresenter ContentSource="SelectedContent"/>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="72"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="34"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#09171B" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <Grid Margin="28,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="USB SENTINEL PRO" FontSize="22" FontWeight="Bold" Foreground="{StaticResource GreenBrush}"/>
                    <TextBlock Text="REMOVABLE MEDIA DEFENSE CONTROL" FontSize="10" Foreground="{StaticResource MutedBrush}"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="#10272D" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                            CornerRadius="5" Padding="12,7" Margin="0,0,14,0">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="8" Height="8" Fill="{Binding ConnectionBrush}" Margin="0,0,8,0"/>
                            <TextBlock Text="{Binding ConnectionText}" Foreground="{StaticResource TextBrush}" FontSize="11"/>
                        </StackPanel>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="DEVELOPED BY" FontSize="9" Foreground="{StaticResource MutedBrush}"/>
                        <TextBlock Text="MUHAMMAD ASHFAQ" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource GreenBrush}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="12,0,0,0">
                        <Button Command="{Binding OpenWebsiteCommand}" Width="32" Height="32" Padding="0" Margin="0,0,5,0" ToolTip="Cyberoly.com"><fa:IconBlock Icon="Globe"/></Button>
                        <Button Command="{Binding OpenGitHubCommand}" Width="32" Height="32" Padding="0" Margin="0,0,5,0" ToolTip="GitHub"><fa:IconBlock Icon="Github"/></Button>
                        <Button Command="{Binding OpenFacebookCommand}" Width="32" Height="32" Padding="0" ToolTip="Facebook"><fa:IconBlock Icon="Facebook"/></Button>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <TabControl Grid.Row="1" Margin="0,0,24,12" Style="{StaticResource SecurityTabs}" TabStripPlacement="Left">
            <TabItem Header="OVERVIEW" Style="{StaticResource SidebarTab}">
                <Grid Margin="22,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="330"/>
                        <ColumnDefinition Width="18"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="18"/>
                        <RowDefinition Height="220"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource Panel}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="SECURITY STATUS" FontSize="12" Foreground="{StaticResource MutedBrush}"/>
                            <Grid Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center" Width="230" Height="230">
                                <Ellipse Stroke="#173139" StrokeThickness="13"/>
                                <Ellipse Stroke="{Binding StatusBrush}" StrokeThickness="13"
                                         StrokeDashArray="1,0.35" StrokeDashCap="Round"
                                         RenderTransformOrigin=".5,.5">
                                    <Ellipse.RenderTransform><RotateTransform Angle="{Binding RingAngle}"/></Ellipse.RenderTransform>
                                </Ellipse>
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="170">
                                    <TextBlock Text="{Binding State}" FontSize="25" FontWeight="Bold"
                                               Foreground="{Binding StatusBrush}" TextAlignment="Center"/>
                                    <TextBlock Text="{Binding ProgressText}" FontSize="16" Margin="0,8,0,0"
                                               Foreground="{StaticResource TextBrush}" TextAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                            <TextBlock Grid.Row="2" Text="{Binding StatusText}" TextWrapping="Wrap"
                                       TextAlignment="Center" Foreground="{StaticResource MutedBrush}"/>
                        </Grid>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource Panel}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="CONTROL CENTER" FontSize="12" Foreground="{StaticResource MutedBrush}"/>
                            <TextBlock Grid.Row="1" Text="Controlled removable storage access"
                                       FontSize="24" FontWeight="SemiBold" Margin="0,20,0,8"/>
                            <StackPanel Grid.Row="2">
                                <TextBlock Text="Every removable drive is checked by Microsoft Defender before access is approved."
                                           Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" MaxWidth="560"
                                           HorizontalAlignment="Left"/>
                                <Grid Margin="0,20,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Background="#0B2024" BorderBrush="#1C5153" BorderThickness="1" CornerRadius="5" Padding="12">
                                        <StackPanel>
                                            <TextBlock Text="POLICY" FontSize="9" Foreground="{StaticResource MutedBrush}"/>
                                            <TextBlock Text="FAIL-CLOSED" Margin="0,4,0,0" FontWeight="SemiBold" Foreground="{StaticResource GreenBrush}"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="2" Background="#0B1C26" BorderBrush="#174858" BorderThickness="1" CornerRadius="5" Padding="12">
                                        <StackPanel>
                                            <TextBlock Text="SCAN ENGINE" FontSize="9" Foreground="{StaticResource MutedBrush}"/>
                                            <TextBlock Text="DEFENDER" Margin="0,4,0,0" FontWeight="SemiBold" Foreground="{StaticResource BlueBrush}"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="4" Background="#1D1720" BorderBrush="#503442" BorderThickness="1" CornerRadius="5" Padding="12">
                                        <StackPanel>
                                            <TextBlock Text="ACCESS GATE" FontSize="9" Foreground="{StaticResource MutedBrush}"/>
                                            <TextBlock Text="SCAN FIRST" Margin="0,4,0,0" FontWeight="SemiBold" Foreground="#FFB86B"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                                <Border Background="{StaticResource PanelAltBrush}" BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="1" CornerRadius="6" Padding="16" Margin="0,24,0,0">
                                    <StackPanel>
                                        <TextBlock Text="DETECTED DRIVES" Foreground="{StaticResource BlueBrush}" FontSize="11"/>
                                        <TextBlock Text="{Binding ConnectedDrivesText}" Margin="0,7,0,0" FontFamily="Cascadia Mono"
                                                   Foreground="{StaticResource TextBrush}"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                            <Grid Grid.Row="3" Margin="0,18,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button Content="ENABLE USB" Command="{Binding EnableCommand}" Height="58"/>
                                <Button Grid.Column="2" Content="DISABLE USB" Command="{Binding DisableCommand}" Height="58"
                                        Background="{StaticResource DangerBrush}" Foreground="White"/>
                            </Grid>
                        </Grid>
                    </Border>

                    <Border Grid.Row="2" Grid.ColumnSpan="3" Style="{StaticResource Panel}" Padding="0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="42"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Background="#0A1519" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                                    CornerRadius="7,7,0,0">
                                <TextBlock Text="LIVE SECURITY LOG" Foreground="{StaticResource BlueBrush}" FontSize="11"
                                           VerticalAlignment="Center" Margin="18,0"/>
                            </Border>
                            <ListBox Grid.Row="1" ItemsSource="{Binding Logs}" Background="Transparent" BorderThickness="0"
                                     Foreground="#A6E8D0" FontFamily="Cascadia Mono" FontSize="12"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled" x:Name="LogList">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" TextWrapping="Wrap" Margin="10,3"/>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>
            <TabItem Header="PROTECTION SETTINGS" Style="{StaticResource SidebarTab}">
                <Grid Margin="22,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="18"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Style="{StaticResource Panel}">
                        <StackPanel>
                            <TextBlock Text="PROTECTION SETTINGS" FontSize="12" Foreground="{StaticResource MutedBrush}"/>
                            <TextBlock Text="USB access policy" FontSize="25" FontWeight="SemiBold" Margin="0,18,0,16"/>
                            <CheckBox Content="Auto disable storage when a removable drive disconnects"
                                      IsChecked="{Binding AutoDisableOnDisconnect}"/>
                            <CheckBox Content="Voice status alerts" IsChecked="{Binding VoiceAlerts}"/>
                            <CheckBox Content="Scan before enable (required)" IsChecked="True" IsEnabled="False"/>
                            <CheckBox Content="Block all new USB device installations"
                                      IsChecked="{Binding BlockAllUsbDevices}"/>
                            <TextBlock Text="Existing keyboard and mouse devices are preserved. Enabling this option can prevent newly connected USB devices from installing."
                                       Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Margin="24,0,0,8"/>
                            <CheckBox Content="Record remediation warnings" IsChecked="{Binding WarnBeforeRemediation}"/>
                            <Button Content="SAVE SETTINGS" Command="{Binding SaveSettingsCommand}"
                                    HorizontalAlignment="Left" Margin="0,24,0,0" MinWidth="180"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="2" Style="{StaticResource Panel}">
                        <StackPanel>
                            <TextBlock Text="SERVICE INFORMATION" FontSize="12" Foreground="{StaticResource MutedBrush}"/>
                            <TextBlock Text="Fail-closed protection" FontSize="21" FontWeight="SemiBold" Margin="0,18,0,12"/>
                            <TextBlock Text="Privileged operations are performed by the USB Sentinel Pro Windows Service. Local commands are accepted only from administrators."
                                       Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap"/>
                            <Separator Background="{StaticResource BorderBrush}" Margin="0,22"/>
                            <TextBlock Text="VOICE ASSISTANT" FontSize="10" Foreground="{StaticResource MutedBrush}"/>
                            <TextBlock Text="{Binding VoiceName}" Foreground="{StaticResource BlueBrush}"
                                       FontWeight="SemiBold" Margin="0,7,0,0" TextWrapping="Wrap"/>
                            <TextBlock Text="A female Windows voice is preferred automatically when installed."
                                       Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="0,6,0,0" TextWrapping="Wrap"/>
                            <Button Content="TEST FEMALE VOICE" Command="{Binding TestVoiceCommand}"
                                    HorizontalAlignment="Left" Margin="0,14,0,0" Padding="16,9"/>
                            <Separator Background="{StaticResource BorderBrush}" Margin="0,18"/>
                            <TextBlock Text="DEFENDER HEALTH" FontSize="10" Foreground="{StaticResource MutedBrush}"/>
                            <TextBlock Text="{Binding DefenderStatusText}" Foreground="{StaticResource GreenBrush}"
                                       FontWeight="SemiBold" Margin="0,7,0,0"/>
                            <TextBlock Text="{Binding DefenderSignatureText}" Foreground="{StaticResource BlueBrush}"
                                       FontFamily="Cascadia Mono" FontSize="11" Margin="0,4,0,0"/>
                            <Separator Background="{StaticResource BorderBrush}" Margin="0,18"/>
                            <TextBlock Text="ADVANCED TOOLS" FontSize="10" Foreground="{StaticResource MutedBrush}"/>
                            <UniformGrid Columns="2" Margin="0,11,0,0">
                                <Button Command="{Binding ChangePasswordCommand}" Margin="0,0,6,7" Padding="10,8" ToolTip="Change USB enable password">
                                    <StackPanel Orientation="Horizontal"><fa:IconBlock Icon="Key" Margin="0,0,7,0"/><TextBlock Text="PASSWORD"/></StackPanel>
                                </Button>
                                <Button Command="{Binding ExportLogsCommand}" Margin="6,0,0,7" Padding="10,8" ToolTip="Export audit log">
                                    <StackPanel Orientation="Horizontal"><fa:IconBlock Icon="FileExport" Margin="0,0,7,0"/><TextBlock Text="EXPORT"/></StackPanel>
                                </Button>
                                <Button Command="{Binding RefreshCommand}" Margin="0,0,6,0" Padding="10,8" ToolTip="Refresh service status">
                                    <StackPanel Orientation="Horizontal"><fa:IconBlock Icon="Rotate" Margin="0,0,7,0"/><TextBlock Text="REFRESH"/></StackPanel>
                                </Button>
                                <Button Command="{Binding OpenSecurityCommand}" Margin="6,0,0,0" Padding="10,8" ToolTip="Open Windows Security history">
                                    <StackPanel Orientation="Horizontal"><fa:IconBlock Icon="Shield" Margin="0,0,7,0"/><TextBlock Text="HISTORY"/></StackPanel>
                                </Button>
                                <Button Command="{Binding RemediateThreatsCommand}" Margin="0,7,6,0" Padding="10,8" ToolTip="Ask Defender to remediate confirmed threats">
                                    <StackPanel Orientation="Horizontal"><fa:IconBlock Icon="ShieldVirus" Margin="0,0,7,0"/><TextBlock Text="REMEDIATE"/></StackPanel>
                                </Button>
                                <Button Command="{Binding FormatUsbCommand}" Margin="6,7,0,0" Padding="10,8" ToolTip="Erase and format a selected USB volume">
                                    <StackPanel Orientation="Horizontal"><fa:IconBlock Icon="HardDrive" Margin="0,0,7,0"/><TextBlock Text="FORMAT USB"/></StackPanel>
                                </Button>
                            </UniformGrid>
                            <Separator Background="{StaticResource BorderBrush}" Margin="0,18"/>
                            <TextBlock Text="Developed by Muhammad Ashfaq" Foreground="{StaticResource GreenBrush}"
                                       FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>
            <TabItem Header="ABOUT &amp; LICENSE" Style="{StaticResource SidebarTab}">
                <Grid Margin="22,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="3*"/>
                        <ColumnDefinition Width="18"/>
                        <ColumnDefinition Width="2*"/>
                    </Grid.ColumnDefinitions>
                    <Border Style="{StaticResource Panel}">
                        <StackPanel>
                            <TextBlock Text="USB SENTINEL PRO" FontSize="11" Foreground="{StaticResource GreenBrush}"/>
                            <TextBlock Text="Free and open-source USB defense" FontSize="26" FontWeight="SemiBold" Margin="0,16,0,12"/>
                            <TextBlock Text="Licensed under the MIT License. Anyone may use, study, modify, and distribute this software subject to the license terms."
                                       Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap"/>
                            <Separator Background="{StaticResource BorderBrush}" Margin="0,24"/>
                            <TextBlock Text="DEFENSIVE USE" FontSize="10" Foreground="{StaticResource BlueBrush}"/>
                            <TextBlock Text="USB Sentinel Pro is defensive security software. It delegates malware detection and remediation to Microsoft Defender and never directly deletes user files."
                                       Foreground="{StaticResource TextBrush}" TextWrapping="Wrap" Margin="0,9,0,0"/>
                            <TextBlock Text="The software is provided without warranty. Administrators remain responsible for deployment, recovery access, backups, and compliance with local policies."
                                       Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Margin="0,12,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="2" Style="{StaticResource Panel}">
                        <StackPanel>
                            <TextBlock Text="PROJECT CREDIT" FontSize="10" Foreground="{StaticResource BlueBrush}"/>
                            <TextBlock Text="Developed by" Foreground="{StaticResource MutedBrush}" Margin="0,20,0,2"/>
                            <TextBlock Text="Muhammad Ashfaq" FontSize="23" FontWeight="SemiBold" Foreground="{StaticResource GreenBrush}"/>
                            <StackPanel Margin="0,20,0,0">
                                <Button Command="{Binding OpenWebsiteCommand}" Margin="0,0,0,8" ToolTip="Visit Cyberoly">
                                    <StackPanel Orientation="Horizontal"><fa:IconBlock Icon="Globe" Width="18" Margin="0,0,10,0"/><TextBlock Text="Cyberoly.com"/></StackPanel>
                                </Button>
                                <Button Command="{Binding OpenGitHubCommand}" Margin="0,0,0,8" ToolTip="Open Muhammad Ashfaq on GitHub">
                                    <StackPanel Orientation="Horizontal"><fa:IconBlock Icon="Github" Width="18" Margin="0,0,10,0"/><TextBlock Text="github.com/MianAshfaq"/></StackPanel>
                                </Button>
                                <Button Command="{Binding OpenFacebookCommand}" ToolTip="Open Muhammad Ashfaq on Facebook">
                                    <StackPanel Orientation="Horizontal"><fa:IconBlock Icon="Facebook" Width="18" Margin="0,0,10,0"/><TextBlock Text="fb.com/MianAshfaq012"/></StackPanel>
                                </Button>
                            </StackPanel>
                            <Separator Background="{StaticResource BorderBrush}" Margin="0,24"/>
                            <TextBlock Text="EDITION" FontSize="10" Foreground="{StaticResource MutedBrush}"/>
                            <TextBlock Text="Community 1.6" Margin="0,7,0,0" FontWeight="SemiBold"/>
                            <TextBlock Text="Microsoft Defender integration" Margin="0,20,0,0" Foreground="{StaticResource MutedBrush}"/>
                            <TextBlock Text="Windows 11 x64" Margin="0,5,0,0" Foreground="{StaticResource MutedBrush}"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>

        <Grid Grid.Row="2" Margin="28,0">
            <TextBlock Text="USB SENTINEL PRO  |  MICROSOFT DEFENDER INTEGRATION  |  DEVELOPED BY MUHAMMAD ASHFAQ"
                       FontSize="10" Foreground="{StaticResource MutedBrush}"/>
            <TextBlock Text="{Binding LastUpdatedText}" HorizontalAlignment="Right" FontSize="10"
                       Foreground="{StaticResource MutedBrush}"/>
        </Grid>
    </Grid>
</Window>
