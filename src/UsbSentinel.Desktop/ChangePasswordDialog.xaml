<Window x:Class="UsbSentinel.Desktop.ChangePasswordDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Change USB Enable Password" Width="500" Height="590" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False">
    <Border Background="#091419" BorderBrush="#2A616A" BorderThickness="1" Padding="30">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock Text="Change security password" FontSize="24" FontWeight="SemiBold" Foreground="#F0F8F8"/>
            <TextBlock Grid.Row="1" Text="Verify the current password, then create a new password with at least 8 characters, one letter, and one number."
                       Foreground="#8BA7AC" TextWrapping="Wrap" Margin="0,8,0,22"/>
            <StackPanel Grid.Row="2">
                <TextBlock Text="CURRENT PASSWORD" FontSize="10" Foreground="#8BA7AC"/>
                <PasswordBox x:Name="CurrentInput" Height="42" Margin="0,7,0,15" Padding="10,7" FontSize="16"
                             Background="#0E2228" Foreground="White" BorderBrush="#28505A"/>
                <TextBlock Text="NEW PASSWORD" FontSize="10" Foreground="#8BA7AC"/>
                <PasswordBox x:Name="NewInput" Height="42" Margin="0,7,0,15" Padding="10,7" FontSize="16"
                             Background="#0E2228" Foreground="White" BorderBrush="#28505A"/>
                <TextBlock Text="CONFIRM NEW PASSWORD" FontSize="10" Foreground="#8BA7AC"/>
                <PasswordBox x:Name="ConfirmInput" Height="42" Margin="0,7,0,0" Padding="10,7" FontSize="16"
                             Background="#0E2228" Foreground="White" BorderBrush="#28505A"/>
                <TextBlock x:Name="ErrorText" Foreground="#FF6A82" FontSize="11" Margin="0,10,0,0" TextWrapping="Wrap"/>
            </StackPanel>
            <Grid Grid.Row="3" Margin="0,22,0,0">
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="10"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                <Button Content="CANCEL" Click="CancelClick" Height="46" Background="#203038" Foreground="White"/>
                <Button Grid.Column="2" Content="SAVE PASSWORD" Click="SaveClick" Height="46"/>
            </Grid>
        </Grid>
    </Border>
</Window>
