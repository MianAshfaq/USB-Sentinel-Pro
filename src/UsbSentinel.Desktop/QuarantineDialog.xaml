<Window x:Class="UsbSentinel.Desktop.QuarantineDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Defender quarantine" Width="760" Height="500" WindowStartupLocation="CenterOwner"
        ResizeMode="CanMinimize" ShowInTaskbar="False">
    <Border Background="{StaticResource BackgroundBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="24">
        <Grid>
            <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
            <StackPanel>
                <TextBlock Text="DEFENDER QUARANTINE" Foreground="{StaticResource BlueBrush}" FontSize="11" FontWeight="Bold"/>
                <TextBlock Text="Review protected detections" FontSize="24" FontWeight="SemiBold" Margin="0,10,0,7"/>
                <TextBlock Text="Restore only a file you trust. Delete permanently removes the selected Defender detection. Both actions require your USB security password."
                           Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap"/>
            </StackPanel>
            <ListBox x:Name="ItemsList" Grid.Row="1" ItemsSource="{Binding Items}" DisplayMemberPath="Summary"
                     Margin="0,20,0,20" Background="{StaticResource PanelAltBrush}" BorderBrush="{StaticResource BorderBrush}"/>
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="10"/><ColumnDefinition/><ColumnDefinition Width="10"/><ColumnDefinition/></Grid.ColumnDefinitions>
                <Button Content="CLOSE" IsCancel="True"/>
                <Button Grid.Column="2" Content="RESTORE SELECTED" Background="{StaticResource BlueBrush}" Click="RestoreClick"/>
                <Button Grid.Column="4" Content="DELETE SELECTED" Background="{StaticResource DangerBrush}" Foreground="White" Click="DeleteClick"/>
            </Grid>
        </Grid>
    </Border>
</Window>
