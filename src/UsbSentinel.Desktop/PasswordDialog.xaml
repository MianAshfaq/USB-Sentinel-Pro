<Window x:Class="UsbSentinel.Desktop.PasswordDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="USB Sentinel Pro Security" Width="500" Height="625" MinHeight="625"
        ResizeMode="NoResize" WindowStartupLocation="CenterOwner" ShowInTaskbar="False">
    <Border Background="#091419" BorderBrush="#2A616A" BorderThickness="1" Padding="30">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Border Width="54" Height="54" CornerRadius="7" Background="#10342F" HorizontalAlignment="Left">
                <TextBlock Text="USB" Foreground="#39FF9A" FontWeight="Bold" FontSize="14"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <TextBlock x:Name="Heading" Grid.Row="1" Text="Authorize USB access" FontSize="24"
                       FontWeight="SemiBold" Foreground="#F0F8F8" Margin="0,18,0,0"/>
            <TextBlock x:Name="Description" Grid.Row="2" Text="Enter your security password to continue."
                       Foreground="#8BA7AC" TextWrapping="Wrap" Margin="0,8,0,18"/>
            <StackPanel Grid.Row="3">
                <TextBlock Text="SECURITY PASSWORD" FontSize="10" Foreground="#8BA7AC"/>
                <PasswordBox x:Name="PasswordInput" Height="42" Margin="0,7,0,0" FontSize="16"
                             Padding="10,7" Background="#0E2228" Foreground="White"
                             BorderBrush="#28505A" PasswordChar="*"/>
                <StackPanel x:Name="ConfirmPanel" Margin="0,13,0,0">
                    <TextBlock Text="CONFIRM PASSWORD" FontSize="10" Foreground="#8BA7AC"/>
                    <PasswordBox x:Name="ConfirmInput" Height="42" Margin="0,7,0,0" FontSize="16"
                                 Padding="10,7" Background="#0E2228" Foreground="White"
                                 BorderBrush="#28505A" PasswordChar="*"/>
                </StackPanel>
                <StackPanel x:Name="ChallengePanel" Margin="0,13,0,0" Visibility="Collapsed">
                    <TextBlock Text="RECOVERY CHECK" FontSize="10" Foreground="#8BA7AC"/>
                    <Grid Margin="0,7,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="170"/>
                        </Grid.ColumnDefinitions>
                        <Border Background="#10342F" BorderBrush="#28505A" BorderThickness="1" Padding="12,10">
                            <TextBlock x:Name="ChallengeQuestion" Foreground="#39FF9A" FontSize="16"
                                       FontWeight="SemiBold"/>
                        </Border>
                        <TextBox x:Name="ChallengeInput" Grid.Column="2" Height="42" FontSize="16"
                                 Padding="10,7" Background="#0E2228" Foreground="White"
                                 BorderBrush="#28505A"/>
                    </Grid>
                </StackPanel>
                <TextBlock x:Name="ErrorText" Foreground="#FF6A82" FontSize="11" Margin="0,9,0,0"
                           TextWrapping="Wrap"/>
            </StackPanel>
            <Grid Grid.Row="5" Margin="0,20,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Content="CANCEL" Click="CancelClick" Height="46" Background="#203038" Foreground="White"/>
                <Button x:Name="ConfirmButton" Grid.Column="2" Content="UNLOCK USB" Click="ConfirmClick" Height="46"/>
            </Grid>
        </Grid>
    </Border>
</Window>
